    #construct figure to compare P0 and PAF 
    .process_ic_selected_model <- function(min_bic_ipw_model_names, min_aic_ipw_model_names,
                                           tag_selection = NULL) {
      P0_bic_selected <- vector()
      P0_aic_selected <- vector()
