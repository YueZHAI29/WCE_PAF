    estimands_mat["Pr_Y_A0 mean", ] <- colMeans(P0_mat)
    estimands_mat["Pr_Y_A0 sd", ] <- matrixStats::colSds(P0_mat)
    estimands_mat["Pr_Y_A0 bias", ] <- colMeans(P0_mat) - P0_true
    estimands_mat["Pr_Y_A0 percent bias", ] <- (colMeans(P0_mat) - P0_true) / P0_true
    P0_true_mat <- matrix(P0_true, nrow = length(list_model_output_i), ncol = length(model_names))
    estimands_mat["Pr_Y_A0 rmse", ] <- sqrt(colMeans((P0_mat - P0_true_mat)^2))
    
    estimands_mat["Pr_Y_A1 mean", ] <- colMeans(P1_mat)
