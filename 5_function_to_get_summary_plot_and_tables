      # Extract values based on selected models
      for (sim_index in 1:n_sim) {
        model_name_bic <- min_bic_ipw_model_names[sim_index]
        model_name_aic <- min_aic_ipw_model_names[sim_index]
        P0_bic_selected[sim_index] <- P0_bias_mat[sim_index, model_name_bic]
        PAF_bic_selected[sim_index] <- PAF_bias_mat[sim_index, model_name_bic]
        P0_aic_selected[sim_index] <- P0_bias_mat[sim_index, model_name_aic]
        PAF_aic_selected[sim_index] <- PAF_bias_mat[sim_index, model_name_aic]
      }
      
      # Add selected model bias values to bias matrices
      P0_bias_mat$BIC_selected_model <- P0_bic_selected
      P0_bias_mat$AIC_selected_model <- P0_aic_selected
      PAF_bias_mat$BIC_selected_model <- PAF_bic_selected
      PAF_bias_mat$AIC_selected_model <- PAF_aic_selected
      
      # Create long-format data frames for plotting
      df_for_P0_plot <- as.data.frame(P0_bias_mat[, models_to_compare]) %>%
        pivot_longer(cols = everything(), names_to = "model", values_to = "P0_bias")
      df_for_PAF_plot <- as.data.frame(PAF_bias_mat[, models_to_compare]) %>%
        pivot_longer(cols = everything(), names_to = "model", values_to = "PAF_bias")
      
      df_for_P0_plot$model <- factor(df_for_P0_plot$model,
                                     levels = models_to_compare,
                                     labels = models_names_label)
      df_for_PAF_plot$model <- factor(df_for_PAF_plot$model,
                                      levels = models_to_compare,
                                      labels = models_names_label)
      
      my_colors <- colorRampPalette(RColorBrewer::brewer.pal(12, "Paired"))(length(unique(df_for_P0_plot$model)))
      plot_P0_bias <- ggplot(df_for_P0_plot, aes(x = model, y = P0_bias, fill = model)) +
        geom_boxplot(alpha = 0.7) +
        geom_jitter(width = 0.2, alpha = 0.9, size = 0.1, color = "skyblue4") +
        labs(title = paste0(tag_element_i, "_Cox WCE MSMs vs. unadjusted","\n",tag_selection), x = "Models", y = "P0 bias") +
        theme_minimal() +
        theme(
          axis.title.x = element_text(size = 14, face = "bold"),
          axis.title.y = element_text(size = 14, face = "bold"),
          axis.text.y = element_text(size = 12, face = "bold"),
          legend.position = "none",
          axis.text.x = element_text(angle = 45, hjust = 1)
        ) +
        stat_summary(fun = mean, geom = "point", shape = 20, size = 3, color = "red3", fill = "red3") +
        coord_flip() +
        geom_hline(yintercept = 0, color = "black", linetype = 1, size = 0.5) +
        scale_fill_manual(values = my_colors)
      
      plot_PAF_bias <- ggplot(df_for_PAF_plot, aes(x = model, y = PAF_bias, fill = model)) +
        geom_boxplot(alpha = 0.7) +
        geom_jitter(width = 0.2, alpha = 0.9, size = 0.1,color = "skyblue4") +
        labs(title = paste0(tag_element_i, "_ Comparison of different Cox WCE MSMs "), x = "Models", y = "PAF bias") +
        theme_minimal() +
        theme(
          axis.title.x = element_text(size = 14, face = "bold"),  # Customize x-axis label
          axis.title.y = element_text(size = 14, face = "bold"),
          axis.text.y = element_text(size = 12, face = "bold"),
          legend.position = "none"
        ) +
        stat_summary(fun = mean, geom="point", shape=20, size=3, color="red3", fill="red3") +
        theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
        coord_flip() +
        geom_hline(yintercept = 0, color = "black", linetype = 1, size = 0.5) +
        scale_fill_manual(values = my_colors)
      
      # Return everything as a list
      return(list(df_for_P0_plot = df_for_P0_plot,
        df_for_PAF_plot = df_for_PAF_plot,
        plot_P0_bias = plot_P0_bias,
        plot_PAF_bias = plot_PAF_bias))
    }
    plot_P0_bias <- .process_ic_selected_model(min_bic_ipw_model_names, min_aic_ipw_model_names)$plot_P0_bias
    plot_PAF_bias <- .process_ic_selected_model(min_bic_ipw_model_names, min_aic_ipw_model_names)$plot_PAF_bias
    plot_P0_bias_unadj <- .process_ic_selected_model(min_bic_model_names, min_aic_model_names,
