    p_value_mat[sim_index, ] <- t(list_model_output_i[[sim_index]][[model_name]][["coefficients"]][, "Pr(>|z|)"])
  } # loop for each simulation
  # Calculate percentage of p-values < 0.05 for each column
  proportion_below_0.05 <- apply(p_value_mat, 2, function(col) {
    mean(col < 0.05)
  })
  names(proportion_below_0.05) <- rownames(list_model_output_i[[1]][[model_name]][["coefficients"]])
    significancy_list[[model_name]] <- proportion_below_0.05
} # loop for model
    
    # min bic/aic selected models
    ipw_bic <- BIC_mat[, colnames(BIC_mat) %in% ipw_model_names]
    ipw_aic <- AIC_mat[, colnames(AIC_mat) %in% ipw_model_names]
    min_bic_ipw_model_names <- apply(ipw_bic, 1, function(row) colnames(ipw_bic)[which.min(row)])
    min_aic_ipw_model_names <- apply(ipw_aic, 1, function(row) colnames(ipw_aic)[which.min(row)])
    
    min_bic_model_names <- apply(BIC_mat, 1, function(row) colnames(BIC_mat)[which.min(row)])
