        # old version: use the KM estimator for true PAF
        # PAF_true_mat[sim_index, model_index] <- (P_observed - P0_true) / P_observed
      } # loop for model
    } # loop for each simulation
  
    # stock the significant rate for each coefficients in each model
    significancy_list <- list()
  for (model_index in seq_along(model_names)) {
  model_name <- model_names[model_index]
  # create a matrix to stock p values
  p_value_mat <- matrix(
    ncol = nrow(list_model_output_i[[1]][[model_name]][["coefficients"]]), # number of covariables
