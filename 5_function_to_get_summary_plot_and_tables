    .get_model_est_weight <- function(model_name, list_model_output_i, sim_index, n.visit = 100){
      model_cutoff <- ifelse(grepl("whole", model_name), n.visit, n.visit / 2)
      est_weight_model_i <- vector(length = n.visit +1)
      
      if (grepl("cum", model_name)){
        model_coef <- list_model_output_i[[sim_index]][[model_name]][["coefficients"]][,"coef"]
        standardized_weight <- rep( 1/(model_cutoff +1), model_cutoff +1)
        est_weight_model_i <- model_coef * standardized_weight
      }
      else if (grepl("null", model_name)){
        est_weight_model_i <- rep(0, model_cutoff +1)
      }
      else if (grepl("current", model_name)){
        model_coef <- list_model_output_i[[sim_index]][[model_name]][["coefficients"]][,"coef"]
        est_weight_model_i <- c(model_coef, rep(0, n.visit/2) )
      }
      else {
        est_weight_model_i <- list_model_output_i[[sim_index]][[model_name]]$coef_weight_predict
      }
    }
    
    for (sim_index in 1:length(list_model_output_i)) {
      model_name_bic <- min_bic_ipw_model_names[sim_index]
      model_name_aic <- min_aic_ipw_model_names[sim_index]
      model_name_bic_wce <- min_bic_wce_model[sim_index]
      model_name_aic_wce <- min_aic_wce_model[sim_index]
      
      # bic selected wce models
      model_cutoff_bic_wce <- ifelse(grepl("whole", model_name_bic_wce), n.visit, n.visit / 2)
      est_weight_bic_selected_wce[sim_index, 1:(model_cutoff_bic_wce + 1)] <- list_model_output_i[[sim_index]][[model_name_bic_wce]]$coef_weight_predict
      
      # aic selected wce models
      model_cutoff_aic_wce <- ifelse(grepl("whole", model_name_aic_wce), n.visit, n.visit / 2)
      est_weight_aic_selected_wce[sim_index, 1:(model_cutoff_aic_wce + 1)] <- list_model_output_i[[sim_index]][[model_name_aic_wce]]$coef_weight_predict
      
      # aic selected models
      est_weight_model_aic <- .get_model_est_weight(model_name = model_name_aic, list_model_output_i, sim_index = sim_index, n.visit = 100)
      model_cutoff_aic <- ifelse(grepl("whole", model_name_aic), n.visit, n.visit / 2)
      est_weight_aic_selected[sim_index, 1:(model_cutoff_aic + 1)] <- est_weight_model_aic
      # bic selected  models
      est_weight_model_bic <- .get_model_est_weight(model_name = model_name_bic, list_model_output_i, sim_index = sim_index, n.visit = 100)
      model_cutoff_bic <- ifelse(grepl("whole", model_name_bic), n.visit, n.visit / 2)
      est_weight_bic_selected[sim_index,  1:(model_cutoff_bic + 1)] <- est_weight_model_bic
    }
    
    est_weight_aic_selected[is.na(est_weight_aic_selected)] <- 0
    est_weight_bic_selected[is.na(est_weight_bic_selected)] <- 0
    est_weight_bic_selected_wce[is.na(est_weight_bic_selected_wce)] <- 0
    est_weight_aic_selected_wce[is.na(est_weight_aic_selected_wce)] <- 0
    
