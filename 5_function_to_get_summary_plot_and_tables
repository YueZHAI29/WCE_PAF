    write_nested_tables <- function(x, file_conn, parent_name = NULL) {
      for (name in names(x)) {
        full_name <- if (!is.null(parent_name)) paste(parent_name, name, sep = " -> ") else name
        
        if (is.list(x[[name]]) && !is.data.frame(x[[name]])) {
          # If the element is a nested list (but not a data.frame), recurse
          cat("### Nested list: ", full_name, " ###\n", file = file_conn, append = TRUE)
          write_nested_tables(x[[name]], file_conn, full_name)
        } else {
          # Otherwise, write the table/data.frame
          cat("### ", full_name, " ###\n", file = file_conn, append = TRUE)
          write.table(x[[name]], file = file_conn, sep = "\t", 
                      row.names = TRUE, col.names = TRUE, append = TRUE, quote = FALSE)
          cat("\n\n", file = file_conn, append = TRUE)
        }
      }
    }
