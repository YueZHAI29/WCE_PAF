    models_names_label <- models_to_compare %>%
      gsub("_", " ", .) %>%                     # replace underscores with spaces
      gsub("cox ipw ", "", .) %>%
      gsub("(?<=\\d)(?=[A-Za-z])", " ", ., perl = TRUE)  %>% # add space after a number if followed by a letter
